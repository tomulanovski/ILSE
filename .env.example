# ILSE User Configuration
# Copy this file to .env and fill in your specific values
# DO NOT commit .env to git (it contains credentials!)

# User identity (optional, for job naming)
GNN_USER=USERNAME

# Conda configuration
GNN_CONDA_PATH=/path/to/miniconda3
GNN_CONDA_ENV=final_project

# Repository path
GNN_REPO_DIR=/path/to/repository

# PostgreSQL Optuna storage (IMPORTANT: Change username and password!)
# Format: postgresql://username:password@host:port/database
#
# The host (compute node) will be AUTO-DETECTED at runtime from:
#   1. ~/.optuna_db_host file (written by PostgreSQL job)
#   2. SLURM queue query
#   3. This .env value as fallback
#
# You can use:
#   - Actual hostname (fallback): your-compute-node
#   - localhost (if using SSH tunnel)
GNN_OPTUNA_STORAGE=postgresql://USERNAME:PASSWORD@your-compute-node:5432/optuna

# ==============================================================================
# CLUSTER CONFIGURATION
# ==============================================================================
# Which cluster are you using? Options: 'bio' or 'cs'
GNN_CLUSTER=bio

# CS CLUSTER SPECIFIC (only needed if GNN_CLUSTER=cs)
# --------------------------------------------------------
# CS cluster account (check with: sacctmgr -P -i show user -s <username>)
GNN_CS_ACCOUNT=gpu-research

# CS cluster priority partition (e.g., gpu-yourlab)
GNN_CS_PRIORITY_PARTITION=gpu-yourlab

# CS cluster general partition (default: killable)
GNN_CS_GENERAL_PARTITION=killable

# CS cluster SSH tunnel configuration (for connecting to another cluster's PostgreSQL)
GNN_BIO_LOGIN=USERNAME@your-cluster-login-node
GNN_SSH_KEY=/home/USERNAME/.ssh/id_rsa

# BIO CLUSTER SPECIFIC (only needed if GNN_CLUSTER=bio)
# --------------------------------------------------------
# Bio cluster priority partition and settings
GNN_BIO_PRIORITY_PARTITION=your-lab-partition
GNN_BIO_PRIORITY_ACCOUNT=your-account
GNN_BIO_PRIORITY_QOS=owner

# Bio cluster general partition and settings
GNN_BIO_GENERAL_PARTITION=gpu-general-pool
GNN_BIO_GENERAL_QOS=public
